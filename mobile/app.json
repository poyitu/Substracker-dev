{
  "expo": {
    "name": "SubsTracker",
    "slug": "substracker",
    "version": "1.0.0",
    "extra": {
      "defaultWorkerUrl": "https://substracker.poyitu8.dpdns.org",
      "router": {},
      "eas": {
        "projectId": "8f40120a-d2dc-4e68-a788-30a96242f2cd"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "substracker",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "SubsTracker uses your calendar to set subscription expiry reminders"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "package": "com.poyitu.substracker"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
